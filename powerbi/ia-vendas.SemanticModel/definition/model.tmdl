model Model
	culture: pt-BR
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: pt-BR
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["dCategoria","dCliente","dForma","dFornecedor","dNota","dProduto","dVendedor","fVendas","BasePath","dTempo","Tabela2"]

ref table dCategoria
ref table dCliente
ref table dForma
ref table dFornecedor
ref table dNota
ref table dProduto
ref table dVendedor
ref table fVendas
ref table _Medidas
ref table dTempo
ref table Tabela2

ref cultureInfo pt-BR

