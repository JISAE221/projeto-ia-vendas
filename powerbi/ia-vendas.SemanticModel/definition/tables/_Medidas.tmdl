	measure 'HTML Abertura' = "<div style=""position:absolute;inset:0;width:100%;height:100%;min-height:680px;background:#09091A;background-image:radial-gradient(ellipse 70% 50% at 50% 0%, rgba(139,92,246,0.10) 0%, transparent 70%);display:flex;align-items:center;justify-content:center;font-family:'Segoe UI',sans-serif""><style>@keyframes iavpulse{0%,100%{opacity:.35;transform:scaleX(.82)}50%{opacity:1;transform:scaleX(1)}}@keyframes iavslide{0%{left:-40%}100%{left:100%}}.iavbar{height:6px;border-radius:9999px;background:#8B5CF6;transform-origin:left center;animation:iavpulse 1.4s ease-in-out infinite}.iavtrack{position:relative;width:240px;height:3px;border-radius:9999px;background:rgba(255,255,255,0.08);overflow:hidden;margin:0 auto}.iavtrack:after{content:'';position:absolute;top:0;left:0;height:100%;width:40%;border-radius:9999px;background:linear-gradient(90deg,#7C3AED,#8B5CF6,#A78BFA);animation:iavslide 1.5s cubic-bezier(.65,0,.35,1) infinite}</style><div style=""text-align:center""><div style=""display:flex;align-items:center;gap:18px;justify-content:center;margin-bottom:30px""><div style=""display:flex;flex-direction:column;gap:7px;align-items:flex-start""><span class=""iavbar"" style=""width:58px""></span><span class=""iavbar"" style=""width:38px;animation-delay:.18s""></span><span class=""iavbar"" style=""width:20px;animation-delay:.36s""></span></div><div style=""text-align:left""><div style=""font-size:40px;font-weight:700;letter-spacing:-0.03em;line-height:1;color:#fff"">IA Vendas</div><div style=""font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:#70709A;margin-top:8px"">Grupo 4 &middot; Biopark Edu</div></div></div><div class=""iavtrack""></div><div style=""font-size:13px;letter-spacing:0.04em;color:#B0B0CC;margin-top:22px"">Carregando an&aacute;lise de vendas&hellip;</div></div></div>"
		lineageTag: a1a1a1a1-0000-4000-8000-000000000002

	measure 'Clientes Únicos' = DISTINCTCOUNT(dCliente[IDCLIENTE])
