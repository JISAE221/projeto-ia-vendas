		lineageTag: a1a1a1a1-0000-4000-8000-000000000014

	measure 'HTML Logo' = "<div style=""display:flex;align-items:center;gap:11px;height:100%;padding-left:6px;font-family:'Segoe UI',sans-serif""><div style=""display:flex;flex-direction:column;gap:4px""><span style=""display:block;height:4px;width:30px;border-radius:9px;background:#8B5CF6""></span><span style=""display:block;height:4px;width:19px;border-radius:9px;background:#8B5CF6""></span><span style=""display:block;height:4px;width:9px;border-radius:9px;background:#8B5CF6""></span></div><div><div style=""font-size:18px;font-weight:700;color:#fff;line-height:1"">IA Vendas</div><div style=""font-size:8px;letter-spacing:0.14em;text-transform:uppercase;color:#70709A;margin-top:3px"">Grupo 4</div></div></div>"
		lineageTag: a1a1a1a1-0000-4000-8000-000000000015

