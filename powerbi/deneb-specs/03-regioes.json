{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Vendas por Região — arraste dCliente[REGIAO] e _Medidas[Total Receita]",
  "data": { "name": "dataset" },
  "width": "container",
  "height": "container",
  "background": "transparent",
  "title": {
    "text": "Vendas por Região",
    "subtitle": "Participação na receita",
    "anchor": "start",
    "color": "#ffffff",
    "fontSize": 15,
    "fontWeight": 600,
    "subtitleColor": "#8888A8",
    "subtitleFontSize": 11,
    "subtitlePadding": 4,
    "offset": 6,
    "dx": 2
  },
  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadius": 8,
        "height": { "band": 0.6 }
      },
      "encoding": {
        "y": {
          "field": "REGIAO",
          "type": "nominal",
          "sort": { "field": "Total Receita", "order": "descending" },
          "title": null,
          "axis": {
            "labelColor": "#e5e7eb",
            "domainColor": "transparent",
            "tickColor": "transparent",
            "labelFontSize": 12
          }
        },
        "x": {
          "field": "Total Receita",
          "type": "quantitative",
          "title": null,
          "axis": { "labels": false, "grid": false, "domainColor": "transparent", "tickColor": "transparent" }
        },
        "color": {
          "field": "Total Receita",
          "type": "quantitative",
          "scale": {
            "range": ["rgba(139,92,246,0.20)", "#8B5CF6"]
          },
          "legend": null
        },
        "tooltip": [
          { "field": "REGIAO", "type": "nominal", "title": "Região" },
          { "field": "Total Receita", "type": "quantitative", "title": "Receita (R$)", "format": ",.2f" }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 6,
        "color": "#9ca3af",
        "fontSize": 11
      },
      "encoding": {
        "y": {
          "field": "REGIAO",
          "type": "nominal",
          "sort": { "field": "Total Receita", "order": "descending" }
        },
        "x": { "field": "Total Receita", "type": "quantitative" },
        "text": { "field": "Total Receita", "type": "quantitative", "format": ",.0f" }
      }
    }
  ],
  "config": {
    "view": { "stroke": "transparent" }
  }
}
