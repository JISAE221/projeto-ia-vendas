{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Fornecedores por Categoria — dCategoria[NOME] + _Medidas[Fornecedores Vendendo]",
  "data": { "name": "dataset" },
  "width": "container",
  "height": "container",
  "background": "transparent",
  "title": {
    "text": "Fornecedores por Categoria",
    "subtitle": "Nº de fornecedores ativos por categoria",
    "anchor": "start",
    "color": "#ffffff",
    "fontSize": 15,
    "fontWeight": 600,
    "subtitleColor": "#8888A8",
    "subtitleFontSize": 11,
    "subtitlePadding": 4,
    "offset": 6,
    "dx": 2
  },
  "encoding": {
    "y": {
      "field": "NOME",
      "type": "nominal",
      "sort": { "field": "Fornecedores Vendendo", "order": "descending" },
      "title": null,
      "axis": { "labelColor": "#e5e7eb", "domainColor": "transparent", "tickColor": "transparent", "labelFontSize": 12 }
    },
    "x": {
      "field": "Fornecedores Vendendo",
      "type": "quantitative",
      "title": null,
      "axis": { "labels": false, "grid": false, "domainColor": "transparent", "tickColor": "transparent" }
    }
  },
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 6, "height": 16 },
      "params": [
        { "name": "sel", "select": { "type": "point", "on": "click", "fields": ["NOME"], "clear": "dblclick" } }
      ],
      "encoding": {
        "color": {
          "field": "Fornecedores Vendendo",
          "type": "quantitative",
          "scale": { "range": ["rgba(139,92,246,0.30)", "#8B5CF6"] },
          "legend": null
        },
        "tooltip": [
          { "field": "NOME", "type": "nominal", "title": "Categoria" },
          { "field": "Fornecedores Vendendo", "type": "quantitative", "title": "Fornecedores", "format": ",.0f" }
        ]
      }
    },
    {
      "mark": { "type": "text", "align": "left", "dx": 6, "color": "#9ca3af", "fontSize": 11 },
      "encoding": { "text": { "field": "Fornecedores Vendendo", "type": "quantitative", "format": ",.0f" } }
    }
  ],
  "config": { "view": { "stroke": "transparent" } }
}
