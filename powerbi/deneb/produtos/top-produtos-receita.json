{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Produtos — Top 10 Produtos por Receita (barra horizontal). Bind: NOME = dProduto[NOME], Total Receita = medida [Total Receita]. Top 10 recalculado dentro do contexto de filtro do PBI.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Top 10 Produtos",
    "subtitle": "Ordenado por receita no período",
    "anchor": "start",
    "color": "#FFFFFF",
    "subtitleColor": "#70709A",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFont": "Inter, Segoe UI",
    "subtitleFontSize": 11
  },
  "transform": [
    { "window": [{ "op": "rank", "as": "rank" }], "sort": [{ "field": "Total Receita", "order": "descending" }] },
    { "filter": "datum.rank <= 10" }
  ],
  "mark": { "type": "bar", "cornerRadiusEnd": 5, "height": { "band": 0.7 }, "tooltip": true },
  "encoding": {
    "y": { "field": "NOME", "type": "nominal", "sort": "-x", "axis": { "title": null, "labelColor": "#E8E8F5", "labelLimit": 180 } },
    "x": { "field": "Total Receita", "type": "quantitative", "axis": { "title": "Receita (R$)", "format": "~s", "grid": true } },
    "color": { "field": "Total Receita", "type": "quantitative", "legend": null, "scale": { "range": ["#7C3AED", "#8B5CF6", "#A78BFA"] } },
    "tooltip": [
      { "field": "NOME", "type": "nominal", "title": "Produto" },
      { "field": "Total Receita", "type": "quantitative", "title": "Receita", "format": "$,.2f" }
    ]
  },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#B0B0CC", "titleColor": "#70709A",
      "gridColor": "#FFFFFF0D", "domainColor": "#FFFFFF14", "tickColor": "#FFFFFF14",
      "labelFont": "Inter, Segoe UI", "titleFont": "Inter, Segoe UI"
    },
    "axisY": { "domain": false, "ticks": false }
  }
}
