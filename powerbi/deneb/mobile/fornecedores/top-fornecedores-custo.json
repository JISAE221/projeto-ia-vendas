{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "MOBILE — Top 6 Fornecedores por Custo (barra horizontal). Bind: NOME = dFornecedor[NOME], Total Custo = medida [Total Custo]. Versão celular: Top 6, rótulo reduzido, sem título de eixo X.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Top 6 Fornecedores",
    "anchor": "start",
    "color": "#FFFFFF",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 12,
    "fontWeight": 600
  },
  "transform": [
    { "window": [{ "op": "rank", "as": "rank" }], "sort": [{ "field": "Total Custo", "order": "descending" }] },
    { "filter": "datum.rank <= 6" }
  ],
  "mark": { "type": "bar", "cornerRadiusEnd": 5, "height": { "band": 0.72 }, "tooltip": true },
  "encoding": {
    "y": { "field": "NOME", "type": "nominal", "sort": "-x", "axis": { "title": null, "labelColor": "#E8E8F5", "labelLimit": 95, "labelFontSize": 9 } },
    "x": { "field": "Total Custo", "type": "quantitative", "axis": { "title": null, "format": "~s", "grid": true, "labelFontSize": 9 } },
    "color": { "field": "Total Custo", "type": "quantitative", "legend": null, "scale": { "range": ["#7C3AED", "#8B5CF6", "#A78BFA"] } },
    "tooltip": [
      { "field": "NOME", "type": "nominal", "title": "Fornecedor" },
      { "field": "Total Custo", "type": "quantitative", "title": "Custo Fornecido", "format": "$,.2f" }
    ]
  },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null },
    "axis": { "labelColor": "#B0B0CC", "titleColor": "#70709A", "gridColor": "#FFFFFF0D", "domainColor": "#FFFFFF14", "tickColor": "#FFFFFF14", "labelFont": "Inter, Segoe UI" },
    "axisY": { "domain": false, "ticks": false }
  }
}
