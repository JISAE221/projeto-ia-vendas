{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "MOBILE — Nº de Fornecedores por Categoria (barra horizontal). Bind: NOME = dCategoria[NOME], Fornecedores = contagem distinta de dFornecedor[IDFORNECEDOR]. Versão celular: barras horizontais (sem rótulos rotacionados), fontes reduzidas.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Fornecedores por Categoria",
    "anchor": "start",
    "color": "#FFFFFF",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 12,
    "fontWeight": 600
  },
  "mark": { "type": "bar", "cornerRadiusEnd": 5, "height": { "band": 0.72 }, "tooltip": true },
  "encoding": {
    "y": { "field": "NOME", "type": "nominal", "sort": "-x", "axis": { "title": null, "labelColor": "#E8E8F5", "labelLimit": 90, "labelFontSize": 9 } },
    "x": { "field": "Fornecedores", "type": "quantitative", "axis": { "title": null, "grid": true, "tickMinStep": 1, "labelFontSize": 9 } },
    "color": {
      "field": "NOME",
      "type": "nominal",
      "legend": null,
      "scale": { "range": ["#8B5CF6", "#A78BFA", "#3B82F6", "#10B981", "#F59E0B", "#EC4899", "#06B6D4", "#EF4444", "#7C3AED"] }
    },
    "tooltip": [
      { "field": "NOME", "type": "nominal", "title": "Categoria" },
      { "field": "Fornecedores", "type": "quantitative", "title": "Fornecedores", "format": ",.0f" }
    ]
  },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null },
    "axis": { "labelColor": "#B0B0CC", "titleColor": "#70709A", "gridColor": "#FFFFFF0D", "domainColor": "#FFFFFF14", "tickColor": "#FFFFFF14", "labelFont": "Inter, Segoe UI" },
    "axisY": { "domain": false, "ticks": false }
  }
}
