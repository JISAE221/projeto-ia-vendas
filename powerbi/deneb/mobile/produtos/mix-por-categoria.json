{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "MOBILE — Mix de Receita por Categoria (donut %). Bind: NOME = dCategoria[NOME], Total Receita = medida [Total Receita]. Versão celular: legenda embaixo em colunas, raios menores, fontes reduzidas.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Mix por Categoria",
    "anchor": "start",
    "color": "#FFFFFF",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 12,
    "fontWeight": 600
  },
  "transform": [
    { "joinaggregate": [{ "op": "sum", "field": "Total Receita", "as": "totalGeral" }] },
    { "calculate": "datum['Total Receita'] / datum.totalGeral", "as": "pct" }
  ],
  "encoding": {
    "theta": { "field": "Total Receita", "type": "quantitative", "stack": true },
    "color": {
      "field": "NOME",
      "type": "nominal",
      "scale": { "range": ["#8B5CF6", "#A78BFA", "#3B82F6", "#10B981", "#F59E0B", "#EC4899", "#06B6D4", "#EF4444", "#7C3AED"] },
      "legend": { "title": null, "orient": "bottom", "direction": "horizontal", "columns": 3, "labelColor": "#B0B0CC", "labelFont": "Inter, Segoe UI", "labelFontSize": 8, "labelLimit": 70, "symbolSize": 60 }
    },
    "tooltip": [
      { "field": "NOME", "type": "nominal", "title": "Categoria" },
      { "field": "Total Receita", "type": "quantitative", "title": "Receita", "format": "$,.2f" },
      { "field": "pct", "type": "quantitative", "title": "Participação", "format": ".1%" }
    ]
  },
  "mark": { "type": "arc", "innerRadius": 40, "outerRadius": 72, "cornerRadius": 3, "padAngle": 0.02, "tooltip": true },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null }
  }
}
