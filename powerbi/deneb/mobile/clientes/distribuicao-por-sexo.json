{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "MOBILE — Distribuição por Sexo (donut). Bind: SEXO = dCliente[SEXO], Clientes Únicos = medida de contagem distinta. Versão celular: legenda embaixo, raios menores, fontes reduzidas.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Distribuição por Sexo",
    "anchor": "start",
    "color": "#FFFFFF",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 12,
    "fontWeight": 600
  },
  "encoding": {
    "theta": { "field": "Clientes Únicos", "type": "quantitative", "stack": true },
    "color": {
      "field": "SEXO",
      "type": "nominal",
      "scale": { "range": ["#8B5CF6", "#3B82F6"] },
      "legend": { "title": null, "orient": "bottom", "direction": "horizontal", "labelColor": "#B0B0CC", "labelFont": "Inter, Segoe UI", "labelFontSize": 9, "symbolSize": 80 }
    },
    "tooltip": [
      { "field": "SEXO", "type": "nominal", "title": "Sexo" },
      { "field": "Clientes Únicos", "type": "quantitative", "title": "Clientes", "format": ",.0f" }
    ]
  },
  "mark": { "type": "arc", "innerRadius": 42, "outerRadius": 72, "cornerRadius": 3, "padAngle": 0.02, "tooltip": true },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null }
  }
}
