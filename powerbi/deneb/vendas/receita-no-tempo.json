{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Vendas — Receita ao longo do tempo (linha + área). Bind: DATA = dTempo[DATA] (eixo temporal), Total Receita = medida [Total Receita]. ATENÇÃO: dTempo foi removida do modelo atual — recriar a dimensão calendário e o relacionamento fVendas[IDTEMPO]→dTempo para este visual funcionar. Responde ao slicer de Período via contexto de filtro do PBI.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Receita no Período",
    "subtitle": "Distribuição diária · acumulado geral",
    "anchor": "start",
    "color": "#FFFFFF",
    "subtitleColor": "#70709A",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFont": "Inter, Segoe UI",
    "subtitleFontSize": 11
  },
  "encoding": {
    "x": {
      "field": "DATA",
      "type": "temporal",
      "axis": { "title": null, "format": "%d/%m", "labelColor": "#B0B0CC", "grid": false }
    },
    "y": {
      "field": "Total Receita",
      "type": "quantitative",
      "axis": { "title": "Receita (R$)", "format": "~s", "grid": true }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "line": { "color": "#8B5CF6", "strokeWidth": 2 },
        "color": {
          "x1": 1, "y1": 1, "x2": 1, "y2": 0,
          "gradient": "linear",
          "stops": [
            { "offset": 0, "color": "#8B5CF600" },
            { "offset": 1, "color": "#8B5CF659" }
          ]
        }
      }
    },
    {
      "mark": { "type": "point", "filled": true, "color": "#A78BFA", "size": 30, "tooltip": true },
      "encoding": {
        "tooltip": [
          { "field": "DATA", "type": "temporal", "title": "Data", "format": "%d/%m/%Y" },
          { "field": "Total Receita", "type": "quantitative", "title": "Receita", "format": "$,.2f" }
        ]
      }
    }
  ],
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#B0B0CC", "titleColor": "#70709A",
      "gridColor": "#FFFFFF0D", "domainColor": "#FFFFFF14", "tickColor": "#FFFFFF14",
      "labelFont": "Inter, Segoe UI", "titleFont": "Inter, Segoe UI"
    }
  }
}
