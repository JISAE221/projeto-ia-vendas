{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Regiões — Receita por Região (barra com rótulo de valor). Bind: REGIAO = dCliente[REGIAO], Total Receita = medida [Total Receita]. Responde a slicers/seleção via contexto de filtro do PBI.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Receita por Região",
    "subtitle": "Ordenado por receita",
    "anchor": "start",
    "color": "#FFFFFF",
    "subtitleColor": "#70709A",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFont": "Inter, Segoe UI",
    "subtitleFontSize": 11
  },
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 6, "tooltip": true },
      "encoding": {
        "color": {
          "field": "REGIAO",
          "type": "nominal",
          "legend": null,
          "scale": { "range": ["#8B5CF6", "#A78BFA", "#3B82F6", "#10B981", "#F59E0B"] }
        }
      }
    },
    {
      "mark": { "type": "text", "align": "center", "baseline": "bottom", "dy": -4, "fill": "#E8E8F5", "font": "Inter, Segoe UI", "fontSize": 10 },
      "encoding": {
        "text": { "field": "Total Receita", "type": "quantitative", "format": "~s" }
      }
    }
  ],
  "encoding": {
    "x": { "field": "REGIAO", "type": "nominal", "sort": "-y", "axis": { "title": null, "labelAngle": 0, "labelColor": "#B0B0CC" } },
    "y": { "field": "Total Receita", "type": "quantitative", "axis": { "title": "Receita (R$)", "format": "~s", "grid": true } },
    "tooltip": [
      { "field": "REGIAO", "type": "nominal", "title": "Região" },
      { "field": "Total Receita", "type": "quantitative", "title": "Receita", "format": "$,.2f" }
    ]
  },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#B0B0CC", "titleColor": "#70709A",
      "gridColor": "#FFFFFF0D", "domainColor": "#FFFFFF14", "tickColor": "#FFFFFF14",
      "labelFont": "Inter, Segoe UI", "titleFont": "Inter, Segoe UI"
    },
    "axisX": { "grid": false }
  }
}
