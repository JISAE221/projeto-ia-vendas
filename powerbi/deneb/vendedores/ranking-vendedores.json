{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Vendedores — Ranking por Receita (barra horizontal com rótulo de posição). Bind: NOME = dVendedor[NOME], Total Receita = medida [Total Receita], Rank Vendedor = medida [Rank Vendedor]. NOTA: não havia Vendedores.html — visual gerado a partir do modelo. Top 15 dentro do contexto de filtro do PBI.",
  "data": { "name": "dataset" },
  "autosize": { "type": "fit", "contains": "padding" },
  "title": {
    "text": "Ranking de Vendedores",
    "subtitle": "Receita acumulada · posição no ranking",
    "anchor": "start",
    "color": "#FFFFFF",
    "subtitleColor": "#70709A",
    "font": "Space Grotesk, Segoe UI",
    "fontSize": 14,
    "fontWeight": 600,
    "subtitleFont": "Inter, Segoe UI",
    "subtitleFontSize": 11
  },
  "transform": [
    { "filter": "datum['Rank Vendedor'] <= 15" }
  ],
  "layer": [
    {
      "mark": { "type": "bar", "cornerRadiusEnd": 5, "height": { "band": 0.72 }, "tooltip": true },
      "encoding": {
        "color": { "field": "Total Receita", "type": "quantitative", "legend": null, "scale": { "range": ["#7C3AED", "#8B5CF6", "#A78BFA"] } }
      }
    },
    {
      "mark": { "type": "text", "align": "left", "dx": 6, "fill": "#E8E8F5", "font": "Inter, Segoe UI", "fontSize": 10 },
      "encoding": {
        "text": { "field": "Total Receita", "type": "quantitative", "format": "~s" }
      }
    }
  ],
  "encoding": {
    "y": {
      "field": "NOME",
      "type": "nominal",
      "sort": { "field": "Rank Vendedor", "order": "ascending" },
      "axis": { "title": null, "labelColor": "#E8E8F5", "labelLimit": 160 }
    },
    "x": { "field": "Total Receita", "type": "quantitative", "axis": { "title": "Receita (R$)", "format": "~s", "grid": true } },
    "tooltip": [
      { "field": "Rank Vendedor", "type": "quantitative", "title": "Posição" },
      { "field": "NOME", "type": "nominal", "title": "Vendedor" },
      { "field": "Total Receita", "type": "quantitative", "title": "Receita", "format": "$,.2f" }
    ]
  },
  "config": {
    "background": "#0E0E21",
    "font": "Inter, Segoe UI, sans-serif",
    "view": { "stroke": null },
    "axis": {
      "labelColor": "#B0B0CC", "titleColor": "#70709A",
      "gridColor": "#FFFFFF0D", "domainColor": "#FFFFFF14", "tickColor": "#FFFFFF14",
      "labelFont": "Inter, Segoe UI", "titleFont": "Inter, Segoe UI"
    },
    "axisY": { "domain": false, "ticks": false }
  }
}
